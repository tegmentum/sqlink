FA4362189661D163FCD6A56D8BF0405AD636AC1BBEDD5CC3EE727DC2AB4A9489
# AES-GCM-256 NIST CAVS decrypt round-trip yields plaintext.
2DB5168E932556F8089A0622981D017D
# Caller-chosen-key round trips: encrypt then decrypt back to text.
hello aes-gcm round trip
hello chacha round trip
# Decrypt failure modes: each must collapse to NULL (no error).
#   wrong key  NULL
<NULL>
#   wrong nonce  NULL
<NULL>
#   wrong AAD  NULL
<NULL>
#   tampered tag (flip last byte of valid ct||tag)  NULL
<NULL>
#   wrong ChaCha key  NULL
<NULL>
# Random helpers return fixed byte lengths (32-byte key, 12-byte nonce).
32
12
# Two successive random keys are not equal (entropy check). `=`
# yields 0 when the BLOBs differ.
0
# aead_version is a non-empty string  length > 0  1.
1
# Decrypt with a malformed key (1 byte instead of 32) collapses to
# NULL, same SQL contract as any other auth failure  no error.
<NULL>
