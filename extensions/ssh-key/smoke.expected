SHA256:+k4u7vS2Jp4JdCiimuRv8+e9VerJv8GU9702LToZeQY
SHA256:AcryHb+GKnxKFEsgh7Fb2HqhEPtgNk7Xyl/3zvmBTJ4
# Acceptance 2b: MD5 fingerprint matches `ssh-keygen -E md5 -lf`.
MD5:91:ba:26:70:ff:da:cd:75:0b:8f:fa:40:c0:37:b9:61
MD5:5e:26:1b:40:9a:7f:0a:96:75:09:a5:17:35:2f:20:2d
MD5:cb:7b:00:fd:7f:9d:39:9b:ae:30:48:6b:0c:cb:35:fe
