package sqlite:wasm@0.1.0;

world sqlite-world {
    // Export both low-level and high-level SQLite APIs
    // WASI filesystem/clock/random support is handled internally
    // via the wasi-sdk libc, not through WIT imports
    export low-level;
    export high-level;
}

// World with extension support
// This world includes the extension API for creating custom functions,
// collations, and hooks. It requires the host to implement the callbacks.
world sqlite-extensible {
    // Export all SQLite APIs
    export low-level;
    export high-level;
    export extension;

    // Import callbacks that SQLite will invoke
    // The host must provide implementations of these callbacks
    import extension-callbacks;
}

// CLI world with extension loading support
// This world is used by the SQLite CLI and includes the ability
// to dynamically load WASM extension components at runtime.
world sqlite-cli {
    // Export all SQLite APIs
    export low-level;
    export high-level;
    export extension;

    // Import callbacks for extension functions
    import extension-callbacks;

    // Import extension loader for .load command support
    import extension-loader;

    // Import ZIP operations for .archive command support
    import zip-operations;
}
