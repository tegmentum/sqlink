package sqlite:wasm@0.1.0;

/// Reactor-shape CLI driver. The CLI used to be a command-mode
/// component (`main()` runs the REPL on its own stack). Follow-up
/// 4 inverts that: the host owns the REPL and calls these methods
/// per line of user input. This shape lets the host stay on the
/// wasm stack — so when a loaded extension fires a host import
/// (e.g. `spi.execute`) the host is free to re-enter `eval` on
/// behalf of the extension, instead of being trapped behind a
/// blocked `main`.
///
/// All methods are sync from the WIT perspective; the host is
/// expected to drive them on an async runtime. See
/// PLAN-reactor-cli-async-host.md for the architectural rationale.
interface cli {
    /// One-time setup: open the database at `db-path` (empty
    /// string means `:memory:`), populate prompt strings.
    /// Idempotent — calling twice is harmless but only the
    /// first call does work.
    init: func(db-path: string) -> result<_, string>;

    /// Process one statement or dot-command. The argument may
    /// contain trailing newlines; the CLI trims them. Returns
    /// the formatted output to print verbatim. Errors are
    /// embedded in the returned string the same way
    /// stderr-bound messages would have been before — the
    /// caller gets one block of text per call.
    eval: func(input: string) -> string;

    /// Programmatic counterpart to `eval`. Bypasses the
    /// human-readable formatter and returns rows + columns +
    /// counters in the same `query-result` shape the rest of
    /// the extension SPI uses — so loaded extensions can
    /// re-enter through `spi.execute` and get back what they'd
    /// have gotten from the canonical SPI surface. Errors
    /// surface as the result variant rather than embedded in
    /// text.
    eval-structured: func(input: string) -> result<query-result, sqlite-error>;

    /// Returns true once the accumulated input ends at a SQL
    /// statement boundary. The host's REPL uses this to know
    /// when to switch between the primary and continuation
    /// prompts and when to call `eval`. Dot-commands are
    /// always complete after a newline.
    is-statement-complete: func(buffered: string) -> bool;

    /// Set to true once the user runs `.quit` (or input EOF is
    /// observed by the CLI's command handlers). The host's REPL
    /// exits when this returns true after an `eval`.
    is-done: func() -> bool;

    /// Current prompt to display. Switches between the main
    /// prompt (typically "sqlite> ") and the continuation prompt
    /// (typically "   ...> ") based on whether the input buffer
    /// is in the middle of a statement.
    current-prompt: func(buffered: string) -> string;

    use sqlite:extension/types@0.1.0.{query-result, sqlite-error};
}
