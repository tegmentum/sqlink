package sqlite:wasm@0.1.0;

/// Minimum interface every Fiji function exports — a single
/// `run() -> result<string, string>` entry point the host calls
/// once per invocation. The function body resolves whatever
/// providers it needs via `compose:dynlink/linker`, does its work,
/// and returns a UTF-8 string for the host to print (or a string
/// error to surface as such).
///
/// Picking this over `wasi:cli/run` because:
/// 1. wasi:cli/run brings in 30+ WASI imports the function probably
///    doesn't use, bloating the component (~150 KB just for stdio
///    plumbing).
/// 2. The return shape we actually want here is `result<string,
///    string>`, not `result<_, ()>` plus stdio writes.
/// 3. The host can pipe the function's output anywhere — SQL row,
///    stdout, structured response — without parsing stdout.
interface fiji {
    run: func() -> result<string, string>;
}

/// World every Fiji function targets. Adds the dynlink import so
/// the function body can resolve `sqlite-runtime` and other
/// shared providers.
world fiji-function {
    import compose:dynlink/linker@0.1.0;
    export fiji;
}
