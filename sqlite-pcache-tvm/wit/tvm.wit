package tvm:memory@0.1.0;

interface types {
  enum region-kind {
    hot-heap,
    object-arena,
    blob-arena,
    page-store,
    scratch,
    device-state,
    code-cache,
  }

  enum residency {
    hot,
    warm,
    cold,
    external,
  }

  record handle {
    region-id: u16,
    generation: u16,
    offset: u32,
  }

  record region-info {
    id: u16,
    generation: u16,
    kind: region-kind,
    capacity: u32,
    used: u32,
    residency: residency,
  }

  // Result of `manager.compact-region`. The caller must use `mapping` to
  // rewrite any handles they hold; old-generation handles fail validation
  // immediately. Mapping pairs are `(old-offset, new-offset)`.
  record compact-result {
    old-generation: u16,
    new-generation: u16,
    mapping: list<tuple<u32, u32>>,
  }

  // Single-call snapshot of every counter the host tracks for a region.
  // Replaces 4 separate diagnostics calls (allocation-count, fault-count,
  // bytes-read-count, bytes-written-count) with one round-trip.
  record region-metrics {
    allocations: u64,
    bytes-allocated: u64,
    bytes-read: u64,
    bytes-written: u64,
    faults: u64,
    promotions: u64,
    demotions: u64,
  }

  variant tvm-error {
    region-not-found(u16),
    stale-handle,
    out-of-bounds,
    not-resident,
    allocation-failed,
    backing-store(string),
    pinned,
  }
}

interface manager {
  use types.{region-kind, handle, region-info, compact-result, tvm-error};

  create-region: func(kind: region-kind, capacity: u32) -> result<u16, tvm-error>;
  destroy-region: func(region-id: u16) -> result<_, tvm-error>;

  alloc: func(region-id: u16, size: u32) -> result<handle, tvm-error>;
  dealloc: func(ptr: handle) -> result<_, tvm-error>;

  describe-region: func(region-id: u16) -> result<region-info, tvm-error>;

  promote-region: func(region-id: u16) -> result<_, tvm-error>;
  demote-region: func(region-id: u16) -> result<_, tvm-error>;
  spill-region: func(region-id: u16) -> result<_, tvm-error>;
  load-region: func(region-id: u16) -> result<_, tvm-error>;

  pin: func(region-id: u16) -> result<_, tvm-error>;
  unpin: func(region-id: u16) -> result<_, tvm-error>;

  // Compact a region (freelist-allocator only). Returns the remap so guests
  // can rewrite live handles. Old-generation handles error after compaction.
  compact-region: func(region-id: u16) -> result<compact-result, tvm-error>;
}

interface bytes {
  use types.{handle, tvm-error};

  read: func(ptr: handle, len: u32) -> result<list<u8>, tvm-error>;
  write: func(ptr: handle, data: list<u8>) -> result<_, tvm-error>;
  copy: func(src: handle, dst: handle, len: u32) -> result<_, tvm-error>;

  // Region-to-region copies that skip the guest's linear memory entirely.
  // Prefer these over read+write when the data flows TVM-region → TVM-region;
  // they avoid the canonical-ABI list lift/lower (~2 copies per call).
  read-into:  func(src: handle, dst-region: u16, dst-offset: u32, len: u32)
              -> result<_, tvm-error>;
  write-from: func(src-region: u16, src-offset: u32, dst: handle, len: u32)
              -> result<_, tvm-error>;
  copy-region: func(src-region: u16, src-offset: u32,
                    dst-region: u16, dst-offset: u32, len: u32)
              -> result<_, tvm-error>;
}

interface diagnostics {
  use types.{region-info, region-metrics, tvm-error};

  list-regions: func() -> list<region-info>;
  fault-count: func(region-id: u16) -> u64;
  allocation-count: func(region-id: u16) -> u64;
  bytes-read-count: func(region-id: u16) -> u64;
  bytes-written-count: func(region-id: u16) -> u64;

  // One-call snapshot of every metric for a region. Prefer this over the
  // individual counter calls when reading multiple — it's a single
  // round-trip and the values are guaranteed consistent (read under the
  // same lock).
  metrics-snapshot: func(region-id: u16) -> result<region-metrics, tvm-error>;
}

// Host-provided interfaces. A guest component imports these; the runtime
// (tvm-wasmtime) implements them in Rust and wires them through Linker.
world tvm-guest {
  import manager;
  import bytes;
  import diagnostics;
}

// Mirror world a host-side component might export (for symmetry / tooling).
world tvm-host {
  export manager;
  export bytes;
  export diagnostics;
}
